# ── Opción A: Nebius Token Factory (recomendado) ─────────────
# API OpenAI-compatible. Modelos open-source (DeepSeek, Llama, Qwen…).
# Obtené tu key en: https://tokenfactory.nebius.com
NEBIUS_API_KEY=your-nebius-api-key-here

# Modelo a usar (opcional, este es el default):
# NEBIUS_MODEL=deepseek-ai/DeepSeek-R1-0528

# ── Opción B: Claude directo (Anthropic) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Opción C: Rutar por OpenSpace (skill caching + evolución) ─
# Levantá OpenSpace con: openspace-mcp --transport streamable-http --host 127.0.0.1 --port 8081
# Definí una skill "philosophy_qa" en tu instancia de OpenSpace.
# OPENSPACE_URL=http://127.0.0.1:8081/mcp

# Prioridad: NEBIUS_API_KEY > ANTHROPIC_API_KEY > OPENSPACE_URL
